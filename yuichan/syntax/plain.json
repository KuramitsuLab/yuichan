{
    "syntax": "Plain English",

    "whitespace": "[ \\t\\r　]",
    "whitespaces": "[ \\t\\r　]+",
    "linefeed": "[\\n]",
    "line-comment-begin": "[#＃]",
    "word-segmenter": " ",
    "comment-begin": "",
    "comment-end": "",
    "indent": "  ",
    "special-names": "how\\s*to()\\using|Remember that()is",

    "null": "[nN]othing",
    "boolean-true": "[yY]es",
    "boolean-false": "[nN]o",

    "number-first-char": "[0-9]",
    "number-chars": "[0-9]*",
    "number-dot-char": "[\\.]",

    "name-first-char": "[A-Za-z_]",
    "name-chars": "[A-Za-z0-9_']*",
    "name-stop-words": "is|are|and|in|to|using|equal",
    "extra-name-begin": "`",
    "extra-name-end": "`",
    
    "string-begin": "\"",
    "string-end": "\"",
    "string-escape": "\\\\",
    "string-interpolation-begin": "\\{",
    "string-interpolation-end": "\\}",
    "string-content-end": "\\\\|\\{|\\\"",

    "array-begin": "\\[",
    "array-end": "\\]",
    "array-separator": "[,、，]",
    "object-begin": "\\{",
    "object-end": "\\}",
    "object-separator": "[,、，]",
    "key-value-separator": ":",

    "grouping-begin": "\\(",
    "grouping-end": "\\)",
 
    "binary-infix+": "\\+",
    "binary-infix-": "-",
    "binary-infix*": "\\*",
    "binary-infix/": "/",
    "binary-infix%": "%",
    "binary-infix==": "==",
    "binary-infix!=": "!=",
    "binary-infix<=": "<=",
    "binary-infix>=": ">=",
    "binary-infix<": "<",
    "binary-infix>": ">",
    "unary-minus": "-",

    "array-indexer-begin": "item",
    "array-indexer-infix": "in",
    "array-indexer-end": "",
    "array-indexer-order": "reverse",
    "array-indexer-suffix": "",
    "length-begin": "the length of",
    "length-end": "",
    
    "funcapp-args-begin": "using",
    "funcapp-args-end": "",
    "funcapp-separator": "and|,",
    "funcapp-noarg": ", do it",

    "import-standard": "Use the standard library",
    "import-begin": "Use",
    "import-end": "",

    "!block-begin": "",
    "block-begin": ":",
    "block-end": "",

    "assignment-begin": "(Remember that|Let)",
    "assignment-infix": "is|are|be",
    "assignment-end": "",

    "increment-begin": "Increase",
    "increment-end": "(by\\s+1)?",
    
    "decrement-begin": "Decrease",
    "decrement-end": "(by\\s+1)?",

    "append-begin": "Add",
    "append-infix": "to(\\s+the\\s+end\\s+of)?",
    "append-end": "",
    "append-order": "reverse",

    "!break": "break",
    "break": "Leave the loop",
    "pass": "Do nothing",
    "print-begin": "Now,",
    "print-end": "",

    "!return-begin": "return",
    "return-begin": "The answer is",
    "return-end": "",
    "return-none": "Stop here",

    "repeat-begin": "Do this",
    "repeat-times": "times|time",
    "repeat-block": "",
    "repeat-end": "End do",

    "!if-begin": "if",
    "if-begin": "When",
    "if-condition-begin": "",
    "if-condition-end": "",
    "if-prefix": "",
    "if-infix==": "(is|are)\\s",
    "if-infix!=": "(is|are) not\\s",
    "if-infix<": "(is|are) less than",
    "if-infix<=": "(is|are) at least",
    "if-infix>": "(is|are) more than",
    "if-infix>=": "(is|are) at most",
    "if-infixin": "(is|are) in\\s",
    "if-infixnotin": "(is|are) not in",
    "if-then": ",\\s+then",
    "if-else": "But,\\s+if not",
    "if-end": "End when",

    "funcdef-begin": "This is how to",
    "funcdef-name-begin": "",
    "funcdef-name-end": "",
    "funcdef-args-begin": "using",
    "funcdef-arg-separator": "and",
    "funcdef-args-end": "",
    "funcdef-noarg": "using nothing",
    "funcdef-block": "",
    "funcdef-end": "That's all",

    "assert-begin": ">>>\\s+",
    "assert-infix": "[\\n]",
    "assert-end": ""
}
