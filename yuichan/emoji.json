{
    "whitespace": "[ \\t\\r　]",
    "whitespaces": "[ \\t\\r　]+",
    "linefeed": "[\\n]",
    "line-comment-begin": "[💭🗨️🚧🔜]",
    "comment-begin": "",
    "comment-end": "",

    "number-begin": "[0-9]",
    "number-chars": "[0-9]*",
    "number-dot-char": "[.]",
    "identifier-begin": "📦[A-Za-z_]",
    "identifier-chars": "[A-Za-z0-9_]*",
    "extra-identifier-begin": "",
    "extra-identifier-end": "",

    "string-begin": "\"",
    "string-end": "\"",
    "string-escape": "\\\\",
    "string-interpolation-begin": "\\{",
    "string-interpolation-end": "\\}",
    "string-content-end": "\\\\|\\{|\\\"",

    "array-begin": "\\[",
    "array-end": "\\]",
    "array-separator": ",",
    "object-begin": "\\{",
    "object-end": "\\}",
    "object-separator": ",",
    "key-value-separator": ":",

    "group-begin!": "\\(",
    "group-end!": "\\)",
    "length-begin": "📏\\s*\\(",
    "length-end": "\\)",

    "binary+": "➕",
    "binary-": "➖",
    "binary*": "✖️",
    "binary/": "➗",
    "binary%": "％",
    "unary-": "-",
    "unary-length": "[📏📐]",
    "unary-inspect": "[🔍👀]",

    "array-index-begin": "\\[",
    "array-index-end": "\\]",
    "property-accessor": "",
    "property-type": "",
    "not-property-name": "",
    "funcapp-begin": "\\(",
    "funcapp-end": "\\)",
    "funcapp-separator": ",",

    "block-begin": "[👉🚩]",
    "block-end": "🔚",
    "block-line": "",

    "assignment-begin": "",
    "assignment-infix": "⬅️",
    "assignment-end": "",

    "increment-begin": "",
    "increment-infix": "⬆️",
    "increment-end": "",

    "decrement-begin": "",
    "decrement-infix": "⬇️",
    "decrement-end": "",

    "append-begin": "",
    "append-infix": "[📎🧲]",
    "append-suffix": "",
    "append-end": "",

    "print-begin": "[✍️✏️]",
    "print-end": "",

    "break": "🛑",
    "continue": "⏭️",
    "pass": "⏸️",

    "return-begin": "[✅💡]",
    "return-end": "",

    "repeat-begin": "[🌀🔁🎯]",
    "repeat-times": "",
    "repeat-block": "",
    "repeat-end": "",

    "if-begin": "[🤔❓]",
    "if-condition-begin": "",
    "if-condition-end": "",
    "if-prefix": "",
    "if-infix==": "⚖️",
    "if-infix!=": "🚫⚖️",
    "if-infix<": "📈",
    "if-infix<=": "📈⚖️",
    "if-infix>": "📉",
    "if-infix>=": "📉⚖️",
    "if-infixin": "📥",
    "if-infixnotin": "🚫📥",
    "if-then": "",
    "if-else": "[🙅❗]",
    "if-end": "",

    "funcdef-begin": "[🛠️🧩🎲]",
    "funcdef-name-begin": "",
    "funcdef-name-end": "",
    "funcdef-args-begin": "\\(",
    "funcdef-noarg": "",
    "funcdef-arg-separator": "\\,",
    "funcdef-args-end": "\\)",
    "funcdef-block": "",
    "funcdef-end": "",

    "assert-begin": "[📌⚠️]",
    "assert-infix": "[✅🎯💡]",
    "assert-end": "",

    "import-begin": "[🗝️🛒]",
    "import-end": "",

    "syntax": "Emoji"
}
