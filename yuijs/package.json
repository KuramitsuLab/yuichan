{
  "name": "yuijs",
  "version": "0.0.1",
  "description": "Yui language — JavaScript implementation (port of yuichan)",
  "type": "module",
  "private": true,
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./syntax/*": "./syntax/*"
  },
  "bin": {
    "yuijs": "./src/main.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test 'test/**/*.test.js'",
    "start": "node src/main.js",
    "build-grammars": "node scripts/build-grammars.js",
    "build-browser": "node scripts/build-browser.js"
  }
}
